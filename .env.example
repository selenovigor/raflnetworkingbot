BOT_TOKEN=1234567890:replace_me

# ID корневого сообщения в группе обсуждений под нужным постом.
# В тесте проще всего: отправить пост в тестовый канал, открыть комментарии,
# написать комментарий, затем посмотреть логи/апдейты и взять root message id.
POST_ID=123

# Необязательно, но лучше указать ID тестовой/боевой группы обсуждений.
# Для супергрупп обычно начинается с -100.
TARGET_CHAT_ID=-1001234567890

# Необязательно: ID канала, если включаем автоактивацию по тексту поста.
SOURCE_CHANNEL_ID=-1001234567890

# Если пост содержит этот текст, бот запомнит его как активный.
POST_MARKER="К кому первым подойдешь на нетворкинге?"

LOG_LEVEL=INFO

# Включить на тестовом прогоне, чтобы увидеть нужные ID в логах.
DEBUG_UPDATES=false
